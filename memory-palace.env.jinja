# Memory Palace configuration generated for {{ friend_name }}.

# Personalization
FRIEND_NAME="{{ friend_name }}"
{% if friend_pronouns %}FRIEND_PRONOUNS="{{ friend_pronouns }}"{% endif %}
FRIEND_RELATIONSHIP="{{ friend_relationship }}"
CLAUDE_NAME="{{ claude_name }}"
PALACE_NAME="{{ palace_name }}"

# Provider credentials
VOYAGE_API_KEY="{{ voyage_api_key }}"
{% if anthropic_api_key %}ANTHROPIC_API_KEY="{{ anthropic_api_key }}"{% endif %}
{% if logfire_token %}LOGFIRE_TOKEN="{{ logfire_token }}"{% endif %}

# Neo4j and OAuth secrets are generated by setup.sh.
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD=
JWT_SECRET_KEY=

# OAuth and HTTP boundary policy
OAUTH_ALLOWED_REDIRECT_URIS='["https://claude.ai/api/mcp/auth_callback","https://claude.com/api/mcp/auth_callback"]'
OAUTH_OWNER_USERNAME="owner"
OAUTH_OWNER_PASSWORD=
PUBLIC_BASE_URL="http://localhost:8000"
CORS_ALLOWED_ORIGINS='["http://localhost:3000"]'

# Runtime
ENVIRONMENT=development
DEBUG=true
DISABLE_DREAM_JOBS=false
