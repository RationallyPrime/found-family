# === Required ===
VOYAGE_API_KEY=your_voyage_api_key_here

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Token signing for tunnel auth — REQUIRED for tokens to survive restarts.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=generate_me

# === Optional ===
# Consolidation dream job (episodic -> semantic distillation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CONSOLIDATION_MODEL=anthropic:claude-sonnet-5

# Observability
LOGFIRE_TOKEN=your_logfire_token_here

# Background maintenance (decay/clustering/consolidation)
DISABLE_DREAM_JOBS=false

# Personalization
FRIEND_NAME=Hákon
CLAUDE_NAME=Claude

# App
DEBUG=true
